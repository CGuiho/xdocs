{
  "name": "@guiho/xdocs",
  "description": "Structured documentation system for codebases. Helps AI make sense of projects.",
  "version": "0.1.0",
  "type": "module",
  "main": "./library/guiho-xdocs.js",
  "types": "./library/guiho-xdocs.d.ts",
  "exports": {
    ".": {
      "types": "./library/guiho-xdocs.d.ts",
      "import": "./library/guiho-xdocs.js"
    }
  },
  "bin": {
    "xdocs": "./library/guiho-xdocs-bin.js"
  },
  "files": [
    "README.md",
    "library/",
    "docs/",
    "jsr.json",
    "CHANGELOG.md",
    "LICENSE.md",
    "docs.md"
  ],
  "keywords": [
    "ai",
    "bun",
    "cli",
    "documentation",
    "xdocs"
  ],
  "license": "MIT",
  "author": {
    "name": "Cristovao GUIHO",
    "email": "cg@guiho.co",
    "url": "https://guiho.co/cg"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --watch source/guiho-xdocs-bin.ts",
    "build": "rm -rf library && tsc -p tsconfig.build.json",
    "binary": "bun build source/guiho-xdocs-bin.ts --compile --outfile bin/xdocs",
    "bundle": "rm -rf bundle && bun build source/guiho-xdocs-bin.ts --outdir bundle --target node --sourcemap=linked",
    "typecheck": "tsc -p . --noEmit",
    "clean": "rm -rf .temp",
    "clean-build": "rm -rf build library bundle bin",
    "clean-installation": "rm -rf node_modules bun.lock",
    "_tc": "bun run typecheck",
    "_ci": "bun clean && bun clean-build && bun clean-installation",
    "_up": "bun _gaa && bun x taze --install --write --interactive",
    "_upb": "bun _gaa && bun update --interactive",
    "_uid": "bun nanoid --alphabet abcdefghijklmnopqrstuvwxyz-_0123456789",
    "_gaa": "npx google-artifactregistry-auth"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CGuiho/xdocs.git",
    "directory": "xdocs"
  },
  "homepage": "https://github.com/CGuiho/xdocs#readme",
  "bugs": {
    "url": "https://github.com/CGuiho/xdocs/issues"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@guiho/mirror": "^3.0.0",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
