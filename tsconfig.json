{
  "include": ["source/**/*"],
  "exclude": ["node_modules", "build", "bundle", "library"],

  "compilerOptions": {
    "lib": ["esnext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": false,
    "resolveJsonModule": true,

    "rootDir": "source",
    "outDir": "library",

    "declaration": true,
    "declarationMap": true,

    "verbatimModuleSyntax": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    "types": ["bun", "node"]
  }
}
